# ========================================

# OTIMIZAÇÃO DE PERFORMANCE - GZIP

# ========================================

# Ativar GZIP para compressão

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml image/svg+xml
</IfModule>

# ========================================

# CACHE DO BROWSER

# ========================================

<IfModule mod_expires.c>
    ExpiresActive On

    # Imagens (30 dias)
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    
    # CSS e JavaScript (1 ano)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    
    # Fontes (1 ano)
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTML e documentos (1 dia)
    ExpiresByType text/html "access plus 1 day"
    
    # Default
    ExpiresDefault "access plus 2 days"
</IfModule>

# ========================================

# OTIMIZAÇÕES ADICIONAIS

# ========================================

# Desabilitar ETags para melhor compatibilidade com cache

<IfModule mod_headers.c>
    Header unset ETag
    FileETag None
</IfModule>

# Habilitar Keep-Alive para reduzir requisições

<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
# ========================================
# SEGURANÇA - Headers HTTP (2026)
# ========================================

<IfModule mod_headers.c>
    # Prevenir clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Prevenir MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy - controlar dados do referrer
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # HSTS - Forçar HTTPS por 2 anos (redundância com PHP, apenas se a conexão for HTTPS)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS
    
    # Cross-Origin Opener Policy (permite popups para links externos)
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    
    # Permissions Policy 2026 (bloqueio de APIs sensíveis do navegador)
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=(), browsing-topics=(), attribution-reporting=()"
</IfModule>

# ========================================

# SEGURANÇA - Proteção de arquivos sensíveis

# ========================================

# Desabilitar listagem de diretórios

Options -Indexes

# Bloquear acesso a arquivos sensíveis

<FilesMatch "\.(git|gitignore|gitmodules|env|htpasswd|ini|log|sh|sql|bak|swp|dist)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear acesso ao composer.json/lock e package.json

<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquear acesso direto a arquivos PHP no diretório vendor

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# Remover informações de versão do servidor

ServerSignature Off

# ========================================
# SEGURANÇA AVANÇADA (WordPress)
# ========================================

# Bloquear acesso ao xmlrpc.php
<Files xmlrpc.php>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Proteger wp-config.php
<Files wp-config.php>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Bloquear enumeração de usuários (Author Scans)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{QUERY_STRING} (author=\d+) [NC]
    RewriteRule .* - [F]
</IfModule>

# Bloquear acesso a arquivos PHP dentro da pasta wp-includes
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^wp-admin/includes/ - [F,L]
    RewriteRule !^wp-includes/ - [S=3]
    RewriteRule ^wp-includes/[^/]+\.php$ - [F,L]
    RewriteRule ^wp-includes/js/tinymce/langs/.+\.php - [F,L]
    RewriteRule ^wp-includes/theme-compat/ - [F,L]
</IfModule>

# Bloquear métodos HTTP perigosos (TRACE, TRACK, DEBUG)
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|DEBUG) [NC]
    RewriteRule .* - [F,L]
</IfModule>
